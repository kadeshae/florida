ance the Future of Internet Testing":"Advance the Future of Internet Testing","Here are just some of the ways we’re making Speedtest better in the near future":"Here are just some of the ways we’re making Speedtest better in the near future","Remove Ads Now":"Remove Ads Now","Remove Ads For Just":"Remove Ads For Just",year:"year","Payment Details":"Payment Details","Name on card":"Name on card","Card Number":"Card Number"," remove ads from Speedtest.net for life":"remove ads from Speedtest.net for life",Pay:"Pay",auto_renew:"One-time charge",ad_free:{team:{title:"What Your Support Does",paragraph:"We’re Ookla<sup>®</sup>, the team behind Speedtest<sup>®</sup>, and we bring people like you insight into the performance of their internet connections. Right now we are able to do that with the support of advertising, but we understand that ads aren’t an ideal part of the user experience.",paragraph2:"Your support of Ookla helps us build better apps, features, and content."},support:{benefit_1:"Actively developing new native apps, getting one step closer to being able to take a Speedtest on any device that connects to the internet.",benefit_2:"Transforming the over 10 million tests taken on Speedtest every day into publicly available analysis on the state of the internet around the world.",benefit_3:"Continuing to refine and advance our purpose-built web test."}},pages:{signup:{title:"Signup for Ad Free",benefits:"If you prefer an ad free experience, this is the best choice for you."},register:{account_benefits:"Join the millions of other people helping us to accelerate the Internet! By creating an\n account, you’ll be able to access your historical results anywhere and manage your\nSpeedtest preferences.",title:"Create an Account",forgot_password:{question:"Do you already have an account, but you forgot your password?",reset_here:"You can reset it here."},resend_confirmation:{question:"Need a new confirmation email?",resend:"You can resend it here."}}},"US avg download":"US avg download","US avg upload":"US avg upload","US avg promise":"US avg promise","US avg value":"US avg value","US avg quality":"US avg quality","Avg download":"Avg download","Avg upload":"Avg upload","Avg promise":"Avg promise","Avg value":"Avg value","Avg quality":"Avg quality","%":"%","$/Mbps":"$/Mbps","/Mb":"/Mb","R-factor":"R-factor","Most Popular Cities":"Most Popular Cities","View More Locations":"View More Locations","Historical Data":"Historical Data","Joining is easy!":"Joining is easy!","Read our":"Read our","Installation Guide":"Installation Guide","before you begin!":"before you begin!","Contact Information":"Contact Information","First Name":"First Name","Last Name":"Last Name","Alternate Contact Email":"Alternate Contact Email","Company Name":"Company Name","Company Website":"Company Website","Phone Number":"Phone Number","Postal Code":"Postal Code","Server City":"Server City","Server State or Region":"State or Region","State or Region":"State or Region",Country:"Country","Server Installation":"Server Installation","Upload URL":"Upload URL","2nd Upload URL":"2nd Upload URL","Ookla Server":"Ookla Server","Hardware Information":"Hardware Information","Current Processor":"Current Processor","Memory Amount":"Memory Amount","Connection Information":"Connection Information","Available Bandwidth":"Available Bandwidth","Uplink/Ethernet Connectivity":"Uplink/Ethernet Connectivity","Less than 100 Mb":"Less than 100 Mb","About 100 Mb":"About 100 Mb","About 1 Gb":"About 1 Gb","More than 1 Gb":"More than 1 Gb","Sponsored By Credit":"Sponsored By Credit","Sponsor Name":"Sponsor Name","Sponsor URL":"Sponsor URL","Additional Information":"Additional Information","By submitting the information in this form, you are consenting to our":"By submitting the information in this form, you are consenting to our",and:"and","Privacy Policy.":"Privacy Policy.","Link to source":"Link to source","Become a Host":"Become a Host",test_final_progress:"Your speed test has completed. Your download speed is {downloadSpeed}, Your upload speed is {uploadSpeed}, and your ping time took {pingTime} milliseconds. Thank you for using Ookla Speedtest.",download_started:"Your download test has started.",upload_started:"Your download test has completed. Your upload test has now started.",download_progress_50:"Your download test is now over fifty percent complete.",upload_progress_50:"Your upload test is now over fifty percent complete.",signup_description:"Enter your payment details below to enable an ad free experience.",create_account_description:"Fill out the form to create your account. We'll complete your registration by sending a confirmation email to the address provided.",browser_upgrade_warning:"Warning: Speedtest may not function properly with your browser, please upgrade.",facebook_test_description:"My download is {download}, and my upload is {upload}. How do your speeds compare?",confirm_result_delete:"This result will be permanently removed from your history. Are you sure you want to remove it?",confirm_unshare_results:"Your share url will be disabled and the old url will no longer work.  Are you sure you want unshare your results?",share_results_modal:"Use one of the links below to share this entire results page with others. You can always stop sharing it via the Unshare button if you change your mind.",adblockHeading:"Ad blocker error",adblockLine1Single:"It appears that your ad blocker is preventing Speedtest from working properly. Please try updating the 3rd party filters in your ad blocker options or add this custom filter to resolve the issue:",adblockLine1Multiple:"It appears that your ad blocker is preventing Speedtest from working properly. Please try updating the 3rd party filters in your ad blocker options or add these custom filters to resolve the issue:",adblockSettings:"We were unable to save your settings due to an ad block rule. There is a list of ad blocking rules named <a target='_blank' href='https://easylist.to/'>EasyList</a> which is causing this problem. To resolve it, either disable the ad blocker while saving or put this filter in your ad blocker options:","Return to Settings":"Return to Settings","Save Failed":"Save Failed",adblockLogin:"We were unable to log in due to an ad block rule. There is a list of ad blocking rules named <a target='_blank' href='https://easylist.to/'>EasyList</a> which is causing this problem. To resolve it, either disable the ad blocker during log in or put this filter in your ad blocker options:","Return to Login":"Return to Log In","Login Failed":"Log In Failed","404message":"We're sorry. The web address you entered is not a functioning page on our site.","500message":"We're sorry. There was a problem with your request.",no_flash_error_1:"Ok, the bad news first: it seems you do not have Flash installed on your machine, which is keeping Speedtest from Speedtesting.",no_flash_error_2:"Now, the good news: Flash is free and super easy to install. Within 30 seconds, an accurate Speedtest result shall be yours.",eu_ip_notification:'Ookla collects certain data through Speedtest that may be considered personally identifiable, such as your IP address, unique device identifiers or location. Ookla believes it has a legitimate interest to share this data with internet providers, hardware manufacturers and industry regulators to help them understand and create a better and faster internet. For further information including how the data may be shared, where the data may be transferred and Ookla’s contact details, please see our <a href="/about/privacy">Privacy Policy</a>.',privacy_updated_notice:'We encourage you to read our updated <a href="/about/privacy">Privacy Policy</a> and <a href="https://www.ziffdavis.com/cookie-policy"> Cookie Policy.',desktop_prompt:{title:{windows:"Try Speedtest for Windows",macos:"Try Speedtest for Mac",other:"Try Speedtest for Desktop"},content:"For download speeds over {speed_threshold} Mbps, we recommend downloading the free Speedtest app for the most accurate testing straight from your computer’s desktop.",close:"Back to test results"},ad_free_prompt:{title:"Remove ads on Speedtest.net for life",content:"$5.00 for ad-free internet testing",cta:"Remove Ads",close:"Back to test results"},test_mode_toggle:{label_connections:"Connections",label_multi:"Multi",label_single:"Single",label_single_connection_test:"Single Connection Test",label_multi_connection:"Multi Connection",label_single_connection:"Single Connection",tooltip_single:"Single connection mode is best for testing over a VPN or simulating a single file download.",tooltip_multi:"Multi connection mode will show your maximum potential speed by using multiple streams in parallel."},"loaded-latency-results-history":{"ping-tooltip":'Does this ping seem low? We’re now displaying interquartile ping instead of minimum ping. <a href="https://www.ookla.com/articles/introducing-loaded-latency">Learn more</a>'},ddeot:{"Having Internet Problems?":"Having Internet Problems?","Popular services with reported issues":"Popular services with reported issues","View all outages on":"View all outages on",Problems:"Problems","Possible Problems":"Possible Problems"},audience:{rate_provider:"RATE YOUR PROVIDER",thanks:"THANKS FOR YOUR FEEDBACK",privacy:'By submitting this feedback, you acknowledge and agree that Ookla may share this information as set forth in its <a href="/about/privacy" target="_blank">Privacy Policy</a>.'},"lower-content":{"desktop-apps":"Desktop Apps","behind-metrics":"Behind the Metrics","troubleshoot-wifi":"Troubleshoot Your Wifi","check-outages":"Check for Outages","talk-to-isp":"Prepare to Talk to Your ISP","how-much-speed":"How Much Speed Do You Need?","get-help":"Get Help","research-header":"Ookla Research<sup>™</sup>","research-copy":"Read the latest analyses of mobile and fixed network performance around the world.","research-cta":"Subscribe","global-index-header":"Speedtest Global Index<sup>™</sup>","global-index-copy":"Find out how your country's internet ranks on the Speedtest Global Index.","global-index-cta":"See Rankings","5g-map-header":"Ookla 5G Map<sup>™</sup>","5g-map-copy":"Discover your nearest 5G deployment on the Ookla 5G Map.","5g-map-cta":"View Map","enterprise-header":"Enterprise Solutions","enterprise-copy":"Learn how to benefit from enterprise-level data on network performance.","enterprise-cta":"See Solutions"},mobile:{"pretest-ad":{header:"Love Speedtest<sup>®</sup>? Get the app",body:"Download Speedtest for advanced metrics, server selection, test history, and more",button:{ios:"Download_on_the_App_Store_Badge_US-UK_RGB_blk_092917.svg",android:"google-play-EN.svg"}},"pretest-ad-new":{header:"Speedtest is better with the app.",body:"Download the Speedtest app for more metrics, video testing, mobile coverage maps, and more.","try-app":"Try the App",skip:"Continue on the web"},"during-test-ad":{body:"Get more metrics, video testing, mobile coverage maps,","extended-text":"and more with the <b>Speedtest app</b>"},"eot-ad":{"shortened-text":"and lots more..."}}}},38130:function(e){e.exports={metadata:{global:{keywords:["ookla","velocidad","prueba","prueba de velocidad","prueba de velocidad de ancho de banda","prueba de velocidad de Internet","prueba de velocidad de banda ancha","speakeasy","flash","cnet","Internet","red","conexión","banda ancha","ancho de banda","latencia","ping","rendimiento","descarga","carga","conexión","dsl","adsl","cable","t1","voip","isp","asp","Internet","ip","dirección ip","tcp","ds3"]},default:{title:"Speedtest por Ookla - La prueba de velocidad de banda ancha global",description:"Use Speedtest en todos sus dispositivos con nuestras aplicaciones gratuitas para escritorio y móvil."},"/awards":{title:"Premios a la banda ancha y redes móviles más veloces | Premios de Speedtest",description:"Hemos estado reuniendo los resultados de Speedtest para determinar las ISP y redes móviles más veloces del mundo."},"/password-reset":{title:"Restablecer contraseña |